#include <stdio.h>

int main() {
    int n, pos, x;

    // Read initial size
    if (scanf("%d", &n) != 1) return 0;

    // Declare array with extra space for the new element
    int arr[n + 1];

    // Read n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Read position and value to insert
    scanf("%d", &pos);
    scanf("%d", &x);

    // Shift elements to the right to make space for x
    // We convert 1-based pos to 0-based index (pos - 1)
    for (int i = n; i >= pos; i--) {
        arr[i] = arr[i - 1];
    }

    // Insert the element at the target index
    arr[pos - 1] = x;

    // Print the updated array
    for (int i = 0; i <= n; i++) {
        printf("%d%s", arr[i], (i == n) ? "" : " ");
    }
    printf("\n");

    return 0;
}
