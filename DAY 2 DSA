#include <stdio.h>

int main() {
    int n, pos;

    // Read initial size
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];

    // Read n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Read 1-based position to delete
    scanf("%d", &pos);

    // Validate position
    if (pos < 1 || pos > n) {
        // If position is invalid, just print original array or handle error
        for (int i = 0; i < n; i++) {
            printf("%d%s", arr[i], (i == n - 1) ? "" : " ");
        }
    } else {
        // Shift elements to the left
        // Start from the index to be deleted (pos-1)
        for (int i = pos - 1; i < n - 1; i++) {
            arr[i] = arr[i + 1];
        }

        // Print the updated array (now size n-1)
        for (int i = 0; i < n - 1; i++) {
            printf("%d%s", arr[i], (i == n - 2) ? "" : " ");
        }
    }
    printf("\n");

    return 0;
}
