#include <stdio.h>
#include <string.h>

#define MAX 1000

int pq[MAX];
int size = 0;

// Helper to peek the highest priority element (smallest value)
int peek() {
    if (size == 0) return -1;
    // Since we keep the array sorted in descending order, 
    // the smallest element is always at the end.
    return pq[size - 1];
}

// Function to insert x while maintaining sorted order
void insert(int x) {
    if (size == MAX) return;

    int i;
    // Shift elements to the right to find the correct spot
    // We sort in descending order so the smallest is at index [size-1]
    for (i = size - 1; i >= 0 && pq[i] < x; i--) {
        pq[i + 1] = pq[i];
    }
    pq[i + 1] = x;
    size++;
}

// Function to delete the highest priority element
int delete() {
    if (size == 0) return -1;
    // The smallest element is at the end of our sorted array
    return pq[--size];
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    char op[10];
    int val;

    for (int i = 0; i < n; i++) {
        scanf("%s", op);
        if (strcmp(op, "insert") == 0) {
            scanf("%d", &val);
            insert(val);
        } else if (strcmp(op, "delete") == 0) {
            int res = delete();
            if (res == -1) printf("-1\n");
            else printf("%d\n", res);
        } else if (strcmp(op, "peek") == 0) {
            int res = peek();
            if (res == -1) printf("-1\n");
            else printf("%d\n", res);
        }
    }

    return 0;
}
