#include <stdio.h>

void reverseArray(int arr[], int n) {
    int left = 0;
    int right = n - 1;
    
    while (left < right) {
        // Swap elements at left and right
        int temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;
        
        // Move pointers towards each other
        left++;
        right--;
    }
}

int main() {
    int n;
    
    // Read size
    if (scanf("%d", &n) != 1) return 0;
    
    int arr[n];
    
    // Read n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    
    // Reverse the array
    reverseArray(arr, n);
    
    // Print reversed array
    for (int i = 0; i < n; i++) {
        printf("%d%s", arr[i], (i == n - 1) ? "" : " ");
    }
    printf("\n");
    
    return 0;
}
