#include <iostream>
#include <vector>
#include <queue>
#include <map>

struct Node {
    int data;
    Node *left, *right;
    Node(int val) : data(val), left(nullptr), right(nullptr) {}
};

// Construct Tree from Level-Order Input
Node* buildTree(const std::vector<int>& arr) {
    if (arr.empty() || arr[0] == -1) return nullptr;
    Node* root = new Node(arr[0]);
    std::queue<Node*> q;
    q.push(root);
    int i = 1;
    while (i < arr.size()) {
        Node* curr = q.front();
        q.pop();
        if (i < arr.size() && arr[i] != -1) {
            curr->left = new Node(arr[i]);
            q.push(curr->left);
        }
        i++;
        if (i < arr.size() && arr[i] != -1) {
            curr->right = new Node(arr[i]);
            q.push(curr->right);
        }
        i++;
    }
    return root;
}

void verticalOrder(Node* root) {
    if (!root) return;

    // Map to store HD as key and list of node values as value
    // std::map automatically keeps keys sorted (leftmost HD to rightmost HD)
    std::map<int, std::vector<int>> columnMap;
    
    // Queue stores {Node, Horizontal Distance}
    std::queue<std::pair<Node*, int>> q;
    q.push({root, 0});

    while (!q.empty()) {
        auto temp = q.front();
        q.pop();
        
        Node* curr = temp.first;
        int hd = temp.second;

        columnMap[hd].push_back(curr->data);

        if (curr->left) q.push({curr->left, hd - 1});
        if (curr->right) q.push({curr->right, hd + 1});
    }

    // Print the columns from leftmost to rightmost
    for (auto const& [hd, nodes] : columnMap) {
        for (int i = 0; i < nodes.size(); i++) {
            std::cout << nodes[i] << (i == nodes.size() - 1 ? "" : " ");
        }
        std::cout << std::endl;
    }
}

int main() {
    int n;
    if (!(std::cin >> n)) return 0;
    std::vector<int> arr(n);
    for (int i = 0; i < n; i++) std::cin >> arr[i];

    Node* root = buildTree(arr);
    verticalOrder(root);

    return 0;
}
