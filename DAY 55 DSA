#include <iostream>
#include <vector>
#include <queue>

struct Node {
    int data;
    Node *left, *right;
    Node(int val) : data(val), left(nullptr), right(nullptr) {}
};

// Standard Level-Order Tree Construction
Node* buildTree(const std::vector<int>& arr) {
    if (arr.empty() || arr[0] == -1) return nullptr;
    Node* root = new Node(arr[0]);
    std::queue<Node*> q;
    q.push(root);
    int i = 1;
    while (i < arr.size()) {
        Node* curr = q.front();
        q.pop();
        if (i < arr.size() && arr[i] != -1) {
            curr->left = new Node(arr[i]);
            q.push(curr->left);
        }
        i++;
        if (i < arr.size() && arr[i] != -1) {
            curr->right = new Node(arr[i]);
            q.push(curr->right);
        }
        i++;
    }
    return root;
}

/**
 * Recursive function to find the Right View
 * @param root Current node
 * @param level Current depth (starting at 0)
 * @param maxLevel Reference to the deepest level reached so far
 */
void getRightView(Node* root, int level, int &maxLevel) {
    if (!root) return;

    // If this is the first time we've reached this level, it's the rightmost node
    if (level > maxLevel) {
        std::cout << root->data << " ";
        maxLevel = level;
    }

    // Traverse Right first to ensure we see rightmost nodes first
    getRightView(root->right, level + 1, maxLevel);
    getRightView(root->left, level + 1, maxLevel);
}

int main() {
    int n;
    if (!(std::cin >> n)) return 0;
    std::vector<int> arr(n);
    for (int i = 0; i < n; i++) std::cin >> arr[i];

    Node* root = buildTree(arr);
    int maxLevel = -1;
    getRightView(root, 0, maxLevel);
    std::cout << std::endl;

    return 0;
