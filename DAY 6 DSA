#include <stdio.h>

int main() {
    int n;

    // Read the size of the array
    if (scanf("%d", &n) != 1) return 0;
    if (n == 0) return 0;

    int arr[n];

    // Read the sorted elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Two-pointer logic: 'j' tracks the position of unique elements
    int j = 0;
    for (int i = 1; i < n; i++) {
        // If current element is different from the last unique element
        if (arr[i] != arr[j]) {
            j++;
            arr[j] = arr[i];
        }
    }

    // Print unique elements from index 0 to j
    for (int i = 0; i <= j; i++) {
        printf("%d%s", arr[i], (i == j) ? "" : " ");
    }
    printf("\n");

    return 0;
}
