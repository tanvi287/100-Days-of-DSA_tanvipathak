#include <iostream>
#include <vector>

using namespace std;

void buildAdjacencyMatrix() {
    int n, m;
    // n = number of vertices, m = number of edges
    if (!(cin >> n >> m)) return;

    // Initialize an n x n matrix with 0
    vector<vector<int>> adjMatrix(n, vector<int>(n, 0));

    for (int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;

        // For an undirected graph:
        adjMatrix[u][v] = 1;
        adjMatrix[v][u] = 1;

        // Note: If the graph is DIRECTED, remove the line: adjMatrix[v][u] = 1;
    }

    // Output the matrix
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << adjMatrix[i][j] << (j == n - 1 ? "" : " ");
        }
        cout << endl;
    }
}

int main() {
    buildAdjacencyMatrix();
    return 0;
}
