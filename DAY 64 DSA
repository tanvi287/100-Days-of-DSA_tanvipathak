#include <iostream>
#include <vector>
#include <queue>

using namespace std;

/**
 * Performs BFS traversal from a given source s.
 * @param n Number of vertices
 * @param adj Adjacency list
 * @param s Source vertex
 */
void performBFS(int n, const vector<vector<int>>& adj, int s) {
    vector<bool> visited(n, false);
    queue<int> q;

    // Start BFS from the source
    visited[s] = true;
    q.push(s);

    cout << "BFS Traversal starting from vertex " << s << ":" << endl;

    while (!q.empty()) {
        int curr = q.front();
        q.pop();

        cout << curr << " ";

        // Explore all neighbors of the current vertex
        for (int neighbor : adj[curr]) {
            if (!visited[neighbor]) {
                visited[neighbor] = true;
                q.push(neighbor);
            }
        }
    }
    cout << endl;
}

int main() {
    int n, m;
    // n = vertices, m = edges
    if (!(cin >> n >> m)) return 0;

    vector<vector<int>> adj(n);
    for (int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u); // Remove for directed graph
    }

    int startNode;
    cin >> startNode;

    performBFS(n, adj, startNode);

    return 0;
}
