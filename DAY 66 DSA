#include <vector>
#include <string>

class Solution {
public:
    bool isCyclic(int V, std::vector<int> adj[]) {
        std::vector<bool> visited(V, false);
        std::vector<bool> recStack(V, false);

        // Check every component to handle disconnected graphs
        for (int i = 0; i < V; i++) {
            if (!visited[i]) {
                if (dfs(i, adj, visited, recStack)) {
                    return true;
                }
            }
        }
        return false;
    }

private:
    bool dfs(int u, std::vector<int> adj[], std::vector<bool>& visited, std::vector<bool>& recStack) {
        // Add current node to visited and recursion stack
        visited[u] = true;
        recStack[u] = true;

        for (int v : adj[u]) {
            // If neighbor not visited, recurse
            if (!visited[v]) {
                if (dfs(v, adj, visited, recStack)) return true;
            }
            // If neighbor is in the current recursion stack, cycle detected
            else if (recStack[v]) {
                return true;
            }
        }

        // Remove node from recursion stack before backtracking
        recStack[u] = false;
        return false;
    }
};
