#include <vector>
#include <stack>
#include <iostream>

class Solution {
public:
    // Function to return list containing vertices in Topological order. 
    std::vector<int> topoSort(int V, std::vector<int> adj[]) {
        std::vector<bool> visited(V, false);
        std::stack<int> st;
        std::vector<int> result;

        // Call the recursive helper function for all unvisited vertices
        for (int i = 0; i < V; i++) {
            if (!visited[i]) {
                dfs(i, adj, visited, st);
            }
        }

        // Pop elements from stack to get the topological order
        while (!st.empty()) {
            result.push_back(st.top());
            st.pop();
        }

        return result;
    }

private:
    void dfs(int u, std::vector<int> adj[], std::vector<bool>& visited, std::stack<int>& st) {
        visited[u] = true;

        // Visit all neighbors of the current vertex
        for (int v : adj[u]) {
            if (!visited[v]) {
                dfs(v, adj, visited, st);
            }
        }

        // Push current vertex to stack after all its neighbors are processed
        st.push(u);
    }
};
