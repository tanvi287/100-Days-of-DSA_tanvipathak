#include <vector>
#include <queue>

class Solution {
public:
    /**
     * Function to return list containing vertices in Topological order.
     * V: number of vertices
     * adj: adjacency list (array of vectors)
     */
    std::vector<int> topoSort(int V, std::vector<int> adj[]) {
        std::vector<int> inDegree(V, 0);
        std::vector<int> topoOrder;
        std::queue<int> q;

        // 1. Calculate in-degree for each vertex
        for (int i = 0; i < V; i++) {
            for (int neighbor : adj[i]) {
                inDegree[neighbor]++;
            }
        }

        // 2. Add all vertices with 0 in-degree to the queue
        for (int i = 0; i < V; i++) {
            if (inDegree[i] == 0) {
                q.push(i);
            }
        }

        // 3. Process the queue
        while (!q.empty()) {
            int u = q.front();
            q.pop();
            topoOrder.push_back(u);

            // For every neighbor, reduce in-degree
            for (int v : adj[u]) {
                inDegree[v]--;
                
                // If in-degree becomes 0, add to queue
                if (inDegree[v] == 0) {
                    q.push(v);
                }
            }
        }

        // Cycle Check: If topoOrder.size() != V, the graph has a cycle
        return topoOrder;
    }
};
