#include <iostream>
#include <vector>
#include <string>
#include <map>

using namespace std;

void findWinner(int n, vector<string>& votes) {
    // Map stores candidate name and their respective vote counts
    // std::map keeps keys sorted lexicographically
    map<string, int> voteCount;
    
    for (const string& name : votes) {
        voteCount[name]++;
    }

    string winner = "";
    int maxVotes = 0;

    // Iterate through the map to find the candidate with max votes
    for (auto const& [name, count] : voteCount) {
        if (count > maxVotes) {
            maxVotes = count;
            winner = name;
        } 
        // If counts are equal, std::map iterator already processed 
        // the lexicographically smaller name first, so we don't 
        // need an explicit tie-break check here if using >.
    }

    cout << winner << " " << maxVotes << endl;
}

int main() {
    int n;
    if (!(cin >> n)) return 0;

    vector<string> votes(n);
    for (int i = 0; i < n; i++) {
        cin >> votes[i];
    }

    findWinner(n, votes);

    return 0;
}
