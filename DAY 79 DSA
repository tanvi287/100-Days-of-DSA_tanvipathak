#include <iostream>
#include <vector>
#include <queue>
#include <climits>

using namespace std;

/**
 * Strategy:
 * 1. Use an adjacency list to store edges and their weights.
 * 2. Maintain a 'dist' array initialized to infinity, with dist[source] = 0.
 * 3. Use a min-priority queue to store pairs of {distance, vertex}.
 * 4. Repeatedly extract the vertex with the smallest distance and relax its neighbors.
 */

void dijkstra(int n, int m, vector<pair<int, int>> adj[], int source) {
    // Distance array initialized to a large value (infinity)
    vector<int> dist(n + 1, INT_MAX);
    dist[source] = 0;

    // Min-priority queue: stores {distance, vertex}
    priority_queue<pair<int, int>, vector<pair<int, int>>, greater<pair<int, int>>> pq;
    pq.push({0, source});

    while (!pq.empty()) {
        int d = pq.top().first;
        int u = pq.top().second;
        pq.pop();

        // If we found a longer path in the queue than already recorded, skip it
        if (d > dist[u]) continue;

        for (auto& edge : adj[u]) {
            int v = edge.first;
            int weight = edge.second;

            // Relaxation Step
            if (dist[u] + weight < dist[v]) {
                dist[v] = dist[u] + weight;
                pq.push({dist[v], v});
            }
        }
    }

    // Output distances for vertices 1 to n
    for (int i = 1; i <= n; i++) {
        if (dist[i] == INT_MAX) cout << "INF ";
        else cout << dist[i] << " ";
    }
    cout << endl;
}

int main() {
    int n, m;
    if (!(cin >> n >> m)) return 0;

    vector<pair<int, int>> adj[n + 1];
    for (int i = 0; i < m; i++) {
        int u, v, w;
        cin >> u >> v >> w;
        adj[u].push_back({v, w});
        adj[v].push_back({u, w}); // Assuming undirected based on sample
    }

    int source;
    cin >> source;

    dijkstra(n, m, adj, source);

    return 0;
}
