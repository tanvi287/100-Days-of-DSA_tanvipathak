#include <iostream>
#include <vector>

using namespace std;

// Lower Bound: First index where arr[mid] >= x
int getLowerBound(int n, const vector<int>& arr, int x) {
    int low = 0, high = n - 1;
    int ans = n; // Default to n if no element is >= x

    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (arr[mid] >= x) {
            ans = mid;     // Potential answer found
            high = mid - 1; // Look for a smaller index on the left
        } else {
            low = mid + 1;  // Look on the right
        }
    }
    return ans;
}

// Upper Bound: First index where arr[mid] > x
int getUpperBound(int n, const vector<int>& arr, int x) {
    int low = 0, high = n - 1;
    int ans = n; // Default to n if no element is > x

    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (arr[mid] > x) {
            ans = mid;     // Potential answer found
            high = mid - 1; // Look for a smaller index on the left
        } else {
            low = mid + 1;  // Look on the right
        }
    }
    return ans;
}

int main() {
    int n, x;
    if (!(cin >> n)) return 0;

    vector<int> arr(n);
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    cin >> x;

    cout << getLowerBound(n, arr, x) << " " << getUpperBound(n, arr, x) << endl;

    return 0;
}
