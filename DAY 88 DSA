#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

// Helper function to check if we can place k cows with at least 'dist' gap
bool canPlace(const vector<int>& stalls, int k, int dist) {
    int count = 1; // Place the first cow in the first stall
    int lastPos = stalls[0];

    for (int i = 1; i < stalls.size(); i++) {
        if (stalls[i] - lastPos >= dist) {
            count++;
            lastPos = stalls[i];
            if (count >= k) return true; // Successfully placed all cows
        }
    }
    return false;
}

int solve() {
    int n, k;
    if (!(cin >> n >> k)) return 0;

    vector<int> stalls(n);
    for (int i = 0; i < n; i++) cin >> stalls[i];

    sort(stalls.begin(), stalls.end());

    int low = 1, high = stalls[n - 1] - stalls[0];
    int ans = 0;

    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (canPlace(stalls, k, mid)) {
            ans = mid;     // mid is a valid minimum distance
            low = mid + 1; // Try to maximize it
        } else {
            high = mid - 1; // Too far apart, try a smaller distance
        }
    }
    return ans;
}

int main() {
    cout << solve() << endl;
    return 0;
}
