#include <iostream>
#include <vector>
#include <numeric>
#include <algorithm>

using namespace std;

// Helper function to check if allocation is possible with a given max page limit
bool canAllocate(const vector<int>& pages, int m, long long maxLimit) {
    int studentsRequired = 1;
    long long currentPages = 0;

    for (int page : pages) {
        if (currentPages + page <= maxLimit) {
            currentPages += page;
        } else {
            studentsRequired++;
            currentPages = page;
            if (studentsRequired > m) return false;
        }
    }
    return true;
}

long long solve() {
    int n, m;
    if (!(cin >> n >> m)) return -1;

    vector<int> pages(n);
    int maxPage = 0;
    long long sumPages = 0;

    for (int i = 0; i < n; i++) {
        cin >> pages[i];
        maxPage = max(maxPage, pages[i]);
        sumPages += pages[i];
    }

    // If students are more than books, it's impossible (since each student needs one book)
    if (m > n) return -1;

    long long low = maxPage;
    long long high = sumPages;
    long long ans = high;

    while (low <= high) {
        long long mid = low + (high - low) / 2;
        if (canAllocate(pages, m, mid)) {
            ans = mid;
            high = mid - 1; // Try to minimize the maximum
        } else {
            low = mid + 1; // Increase limit to allow more pages per student
        }
    }
    return ans;
}

int main() {
    cout << solve() << endl;
    return 0;
}
