#include <iostream>
#include <vector>
#include <numeric>
#include <algorithm>

using namespace std;

// Helper function to check if allocation is possible within a given maxTime
bool canPaint(const vector<int>& boards, int k, long long maxTime) {
    int paintersRequired = 1;
    long long currentBoardSum = 0;

    for (int length : boards) {
        if (currentBoardSum + length <= maxTime) {
            currentBoardSum += length;
        } else {
            paintersRequired++;
            currentBoardSum = length;
            if (paintersRequired > k) return false;
        }
    }
    return true;
}

long long solve() {
    int n, k;
    if (!(cin >> n >> k)) return -1;

    vector<int> boards(n);
    int maxBoard = 0;
    long long totalLength = 0;

    for (int i = 0; i < n; i++) {
        cin >> boards[i];
        maxBoard = max(maxBoard, boards[i]);
        totalLength += boards[i];
    }

    long long low = maxBoard;
    long long high = totalLength;
    long long ans = totalLength;

    while (low <= high) {
        long long mid = low + (high - low) / 2;
        if (canPaint(boards, k, mid)) {
            ans = mid;     // Potential minimum time found
            high = mid - 1; // Try to find a smaller time
        } else {
            low = mid + 1;  // Not enough time, increase limit
        }
    }
    return ans;
}

int main() {
    cout << solve() << endl;
    return 0;
}
