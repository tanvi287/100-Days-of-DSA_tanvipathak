#include <iostream>
#include <vector>

using namespace std;

// Function to merge two sorted halves and count split inversions
long long mergeAndCount(vector<int>& arr, int low, int mid, int high) {
    int n1 = mid - low + 1;
    int n2 = high - mid;
    
    vector<int> left(n1), right(n2);
    for (int i = 0; i < n1; i++) left[i] = arr[low + i];
    for (int j = 0; j < n2; j++) right[j] = arr[mid + 1 + j];

    long long count = 0;
    int i = 0, j = 0, k = low;

    while (i < n1 && j < n2) {
        if (left[i] <= right[j]) {
            arr[k++] = left[i++];
        } else {
            // arr[left] > arr[right], so an inversion exists
            // All remaining elements in left[] are greater than right[j]
            arr[k++] = right[j++];
            count += (n1 - i); 
        }
    }

    while (i < n1) arr[k++] = left[i++];
    while (j < n2) arr[k++] = right[j++];

    return count;
}

// Recursive function to sort and count inversions
long long countInversions(vector<int>& arr, int low, int high) {
    long long count = 0;
    if (low < high) {
        int mid = low + (high - low) / 2;
        
        count += countInversions(arr, low, mid);      // Left inversions
        count += countInversions(arr, mid + 1, high);  // Right inversions
        count += mergeAndCount(arr, low, mid, high);   // Split inversions
    }
    return count;
}

int main() {
    int n;
    if (!(cin >> n)) return 0;
    
    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];

    cout << countInversions(arr, 0, n - 1) << endl;
    
    return 0;
}
