#include <iostream>
#include <vector>
#include <algorithm>
#include <queue>

using namespace std;

struct Interval {
    int start, end;
};

int minMeetingRooms(vector<Interval>& intervals) {
    if (intervals.empty()) return 0;

    // 1. Sort intervals by start time
    sort(intervals.begin(), intervals.end(), [](const Interval& a, const Interval& b) {
        return a.start < b.start;
    });

    // 2. Min-heap to track the end times of meetings in rooms
    priority_queue<int, vector<int>, greater<int>> minHeap;

    // 3. Add the first meeting's end time
    minHeap.push(intervals[0].end);

    for (int i = 1; i < intervals.size(); i++) {
        // If the current meeting starts after the earliest meeting ends, reuse the room
        if (intervals[i].start >= minHeap.top()) {
            minHeap.pop();
        }
        
        // Push the end time of the current meeting (either updates room or adds new)
        minHeap.push(intervals[i].end);
    }

    return minHeap.size();
}

int main() {
    vector<Interval> intervals = {{0, 30}, {5, 10}, {15, 20}};
    cout << "Minimum rooms required: " << minMeetingRooms(intervals) << endl;
    return 0;
}
