#include <stdio.h>
#include <string.h>

int main() {
    char str[1001];

    // Read the input string
    if (scanf("%s", str) != 1) return 0;

    int n = strlen(str);
    int left = 0;
    int right = n - 1;
    int isPalindrome = 1; // Assume it is a palindrome (1 for YES)

    // Two-pointer comparison
    while (left < right) {
        if (str[left] != str[right]) {
            isPalindrome = 0; // Found a mismatch
            break;
        }
        left++;
        right--;
    }

    // Output the result
    if (isPalindrome) {
        printf("YES\n");
    } else {
        printf("NO\n");
    }

    return 0;
}
