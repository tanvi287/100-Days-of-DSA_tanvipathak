#include <stdio.h>

int main() {
    int m, n;

    // Read rows and columns
    if (scanf("%d %d", &m, &n) != 2) return 0;

    // Condition 1: A symmetric matrix must be square
    if (m != n) {
        printf("Not a Symmetric Matrix\n");
        return 0;
    }

    int matrix[m][n];

    // Read the matrix elements
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int isSymmetric = 1; // Assume symmetric

    // Condition 2: Check if matrix[i][j] == matrix[j][i]
    for (int i = 0; i < m; i++) {
        // We only need to check the upper or lower triangle
        for (int j = i + 1; j < n; j++) {
            if (matrix[i][j] != matrix[j][i]) {
                isSymmetric = 0;
                break;
            }
        }
        if (!isSymmetric) break;
    }

    if (isSymmetric) {
        printf("Symmetric Matrix\n");
    } else {
        printf("Not a Symmetric Matrix\n");
    }

    return 0;
}
