#include <stdio.h>

int main() {
    int n;

    // Read the size of the square matrix
    if (scanf("%d", &n) != 1) return 0;

    int matrix[n][n];
    int isIdentity = 1; // Assume it is an identity matrix

    // Read matrix elements and verify conditions simultaneously
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);

            // Check Identity conditions
            if (i == j) {
                // Main diagonal elements must be 1
                if (matrix[i][j] != 1) {
                    isIdentity = 0;
                }
            } else {
                // All other elements must be 0
                if (matrix[i][j] != 0) {
                    isIdentity = 0;
                }
            }
        }
    }

    // Final Output
    if (isIdentity) {
        printf("Identity Matrix\n");
    } else {
        printf("Not an Identity Matrix\n");
    }

    return 0;
}
