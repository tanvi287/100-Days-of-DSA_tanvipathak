#include <stdio.h>

int main() {
    int m, n;

    // Read rows and columns
    if (scanf("%d %d", &m, &n) != 2) return 0;

    int matrix[m][n];
    long long diagonalSum = 0;

    // Read the matrix elements
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    // Calculate sum of primary diagonal (i == j)
    // The diagonal length is the minimum of m and n
    int limit = (m < n) ? m : n;
    for (int i = 0; i < limit; i++) {
        diagonalSum += matrix[i][i];
    }

    // Print the final sum
    printf("%lld\n", diagonalSum);

    return 0;
}
