#include <stdio.h>

int main() {
    int n;

    // Read the size of the array
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    int visited[n]; // To keep track of elements we've already counted

    // Read array elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        visited[i] = 0; // Initialize visited array to 0 (False)
    }

    int first = 1; // Helper for formatting output spaces

    for (int i = 0; i < n; i++) {
        // Skip if this element has already been counted
        if (visited[i] == 1) {
            continue;
        }

        int count = 1;
        // Search for duplicates in the remaining part of the array
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                visited[j] = 1; // Mark as visited so we don't process it again
            }
        }

        // Output formatting: element:count
        if (!first) printf(" ");
        printf("%d:%d", arr[i], count);
        first = 0;
    }

    printf("\n");
    return 0;
}
