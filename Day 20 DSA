#include <stdio.h>

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int count = 0;

    // Outer loop picks the starting point
    for (int i = 0; i < n; i++) {
        int current_sum = 0;
        
        // Inner loop picks the ending point and calculates sum
        for (int j = i; j < n; j++) {
            current_sum += arr[j];
            
            if (current_sum == 0) {
                count++;
            }
        }
    }

    printf("%d\n", count);

    return 0;
}
