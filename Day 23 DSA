#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

// Helper to create and return a new node
struct Node* createNode(int val) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = val;
    newNode->next = NULL;
    return newNode;
}

// Function to merge two sorted lists
struct Node* mergeLists(struct Node* l1, struct Node* l2) {
    struct Node dummy; // Stack allocated dummy node
    struct Node* tail = &dummy;
    dummy.next = NULL;

    while (l1 != NULL && l2 != NULL) {
        if (l1->data <= l2->data) {
            tail->next = l1;
            l1 = l1->next;
        } else {
            tail->next = l2;
            l2 = l2->next;
        }
        tail = tail->next;
    }

    // If one list is exhausted, attach the remainder of the other
    if (l1 != NULL) tail->next = l1;
    else tail->next = l2;

    return dummy.next;
}

int main() {
    int n, m, val;
    struct Node *head1 = NULL, *head2 = NULL, *temp = NULL;

    // Input first list
    if (scanf("%d", &n) == 1) {
        for (int i = 0; i < n; i++) {
            scanf("%d", &val);
            struct Node* newNode = createNode(val);
            if (!head1) head1 = temp = newNode;
            else { temp->next = newNode; temp = newNode; }
        }
    }

    // Input second list
    if (scanf("%d", &m) == 1) {
        for (int i = 0; i < m; i++) {
            scanf("%d", &val);
            struct Node* newNode = createNode(val);
            if (!head2) head2 = temp = newNode;
            else { temp->next = newNode; temp = newNode; }
        }
    }

    // Merge and Print
    struct Node* mergedHead = mergeLists(head1, head2);
    struct Node* curr = mergedHead;
    while (curr) {
        printf("%d%s", curr->data, (curr->next ? " " : ""));
        curr = curr->next;
    }
    printf("\n");

    return 0;
}
