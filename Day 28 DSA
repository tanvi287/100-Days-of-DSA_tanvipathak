#include <stdio.h>
#include <stdlib.h>

// Define the structure for a node
struct Node {
    int data;
    struct Node* next;
};

// Function to create a circular linked list
struct Node* createList(int n) {
    if (n <= 0) return NULL;

    struct Node *head = NULL, *temp = NULL, *newNode = NULL;
    int val;

    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        
        // Allocate memory for the new node
        newNode = (struct Node*)malloc(sizeof(struct Node));
        newNode->data = val;

        if (head == NULL) {
            head = newNode;
            newNode->next = head; // Point to itself initially
            temp = head;
        } else {
            temp->next = newNode;
            newNode->next = head; // Link back to head
            temp = newNode;       // Move temp to the new last node
        }
    }
    return head;
}

// Function to traverse and print the list
void displayList(struct Node* head) {
    if (head == NULL) return;

    struct Node* temp = head;
    do {
        printf("%d ", temp->data);
        temp = temp->next;
    } while (temp != head); // Stop when we wrap back to head
    printf("\n");
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    struct Node* head = createList(n);
    displayList(head);

    return 0;
}
