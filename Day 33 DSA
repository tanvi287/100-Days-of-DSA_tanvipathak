#include <stdio.h>
#include <ctype.h>
#include <string.h>

#define MAX 100

char stack[MAX];
int top = -1;

void push(char c) {
    stack[++top] = c;
}

char pop() {
    return stack[top--];
}

// Function to return precedence of operators
int precedence(char c) {
    if (c == '^') return 3;
    if (c == '*' || c == '/') return 2;
    if (c == '+' || c == '-') return 1;
    return 0;
}

void infixToPostfix(char* infix) {
    for (int i = 0; infix[i] != '\0'; i++) {
        char c = infix[i];

        // 1. If character is an operand, print it
        if (isalnum(c)) {
            printf("%c", c);
        }
        // 2. If character is '(', push to stack
        else if (c == '(') {
            push(c);
        }
        // 3. If character is ')', pop until '(' is found
        else if (c == ')') {
            while (top != -1 && stack[top] != '(') {
                printf("%c", pop());
            }
            pop(); // Remove '(' from stack
        }
        // 4. If character is an operator
        else {
            while (top != -1 && precedence(stack[top]) >= precedence(c)) {
                printf("%c", pop());
            }
            push(c);
        }
    }

    // Pop all remaining operators from the stack
    while (top != -1) {
        printf("%c", pop());
    }
    printf("\n");
}

int main() {
    char infix[MAX];
    scanf("%s", infix);
    infixToPostfix(infix);
    return 0;
}
