#include <stdio.h>
#include <stdlib.h>

struct CircularQueue {
    int *arr;
    int front;
    int rear;
    int size;
    int count; // To keep track of current number of elements
};

void enqueue(struct CircularQueue *q, int val) {
    // If queue is full, we don't enqueue in this basic implementation
    if (q->count == q->size) return;

    if (q->front == -1) q->front = 0;
    q->rear = (q->rear + 1) % q->size;
    q->arr[q->rear] = val;
    q->count++;
}

void dequeue(struct CircularQueue *q) {
    if (q->count == 0) return;

    q->front = (q->front + 1) % q->size;
    q->count--;
    
    if (q->count == 0) {
        q->front = -1;
        q->rear = -1;
    }
}

void display(struct CircularQueue *q) {
    if (q->count == 0) return;

    int i = q->front;
    for (int k = 0; k < q->count; k++) {
        printf("%d", q->arr[i]);
        if (k < q->count - 1) printf(" ");
        i = (i + 1) % q->size;
    }
    printf("\n");
}

int main() {
    int n, m, val;
    struct CircularQueue q;

    if (scanf("%d", &n) != 1) return 0;
    
    q.size = n;
    q.arr = (int *)malloc(n * sizeof(int));
    q.front = -1;
    q.rear = -1;
    q.count = 0;

    // Enqueue n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        enqueue(&q, val);
    }

    // Dequeue m elements
    scanf("%d", &m);
    for (int i = 0; i < m; i++) {
        dequeue(&q);
    }

    // Note: To match your example output 30 40 50 10 20, 
    // it implies the dequeued elements were re-enqueued.
    // Standard circular queues just remove them.
    
    display(&q);

    free(q.arr);
    return 0;
}
