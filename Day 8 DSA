#include <stdio.h>

// Recursive function to calculate a raised to power b
long long power(int a, int b) {
    // Base case: any number to the power of 0 is 1
    if (b == 0) {
        return 1;
    }
    
    // Recursive step: a^b = a * a^(b-1)
    return a * power(a, b - 1);
}

int main() {
    int a, b;

    // Read base (a) and exponent (b)
    if (scanf("%d %d", &a, &b) != 2) return 0;

    // We use long long to handle larger results
    printf("%lld\n", power(a, b));

    return 0;
}
